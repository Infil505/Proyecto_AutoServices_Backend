{
  "name": "proyecto_autoservices_backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/seed.ts",
    "dev": "bun run index.ts",
    "build": "bun build ./index.ts --target node --outfile dist/index.js --format esm",
    "start": "NODE_ENV=production bun run index.ts",
    "test": "bun test tests/*.test.ts",
    "test:integration": "bun test tests/integration/",
    "test:all": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^20.19.37",
    "@types/pdfkit": "^0.17.5",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "helmet": "^7.2.0",
    "hono": "^4.12.8",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.8",
    "resend": "^6.10.0",
    "swagger-ui": "^5.32.1",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "ws": "^8.13.0",
    "zod": "^3.25.76"
  }
}
